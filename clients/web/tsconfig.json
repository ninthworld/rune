{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@protocol-fixtures/gameview.json": ["../../crates/rune-protocol/fixtures/gameview.json"],
      "@protocol-fixtures/gameview-over.json": [
        "../../crates/rune-protocol/fixtures/gameview-over.json"
      ],
      "@protocol-fixtures/gameview-prompts.json": [
        "../../crates/rune-protocol/fixtures/gameview-prompts.json"
      ]
    }
  },
  "include": ["src"]
}
