# RUNE web client environment (copy to .env.local for local overrides).
#
# Default WebSocket URL the connection screen pre-fills. The server's default
# listen address is 127.0.0.1:9000 (see crates/rune-cli DEFAULT_ADDR); the client
# uses the `localhost` hostname. Editable at runtime in the connection screen.
VITE_RUNE_SERVER_URL=ws://localhost:9000
