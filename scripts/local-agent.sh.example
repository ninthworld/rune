#!/usr/bin/env bash
#
# local-agent.sh — drive one RUNE agent-task issue to a PR with a local model.
#
# This is an EXAMPLE. Copy it, drop the `.example` suffix, review it, and adjust
# the harness invocation to your setup. It is intentionally not wired into `make`
# or CI. See docs/agents/local-ai-setup.md for the full walkthrough.
#
# Prerequisites:
#   - Ollama serving a large-context model (see docs/agents/local-ai-setup.md, Step 1)
#   - `gh` authenticated with `repo` + `workflow` scopes (Step 2)
#   - A terminal agent — OpenCode by default; swap in `aider` if you prefer (Step 3)
#
# Usage: ./scripts/local-agent.sh <issue-number>

set -euo pipefail

MODEL="${RUNE_AGENT_MODEL:-ollama/qwen3-coder-agent}"

if [ "$#" -ne 1 ]; then
  echo "usage: $0 <issue-number>" >&2
  exit 2
fi
ISSUE="$1"

# Derive a branch slug from the issue title: lowercase, spaces→dashes, strip the
# rest, cap the length. Produces the repo's `agent/<issue>-<slug>` convention.
TITLE="$(gh issue view "$ISSUE" --json title --jq .title)"
SLUG="$(printf '%s' "$TITLE" \
  | tr '[:upper:] ' '[:lower:]-' \
  | tr -cd 'a-z0-9-' \
  | cut -c1-40)"
BRANCH="agent/${ISSUE}-${SLUG}"

git fetch origin main
git switch -c "$BRANCH" origin/main

ISSUE_FILE="$(mktemp)"
trap 'rm -f "$ISSUE_FILE"' EXIT
gh issue view "$ISSUE" >"$ISSUE_FILE"

# Hand the issue to the harness non-interactively. Replace this block with your
# agent of choice; the contract is "edit the working tree to satisfy the issue".
opencode run --model "$MODEL" "$(cat <<PROMPT
Implement GitHub issue #${ISSUE} for this repository.

Follow AGENTS.md and docs/coding-standards.md. Make the SMALLEST change that
satisfies the acceptance criteria. Add or update tests for anything you change.
Run 'make check' and fix failures before you finish. Use Conventional Commits.

--- issue #${ISSUE} ---
$(cat "$ISSUE_FILE")
PROMPT
)"

# The real gate: this mirrors the Engine and Client CI jobs exactly. Do not trust
# the model's claim that it passed — verify.
make check

git push -u origin "$BRANCH"
gh pr create --fill --body "Closes #${ISSUE}"

echo "Opened PR for issue #${ISSUE} from ${BRANCH}. Review before merging."
