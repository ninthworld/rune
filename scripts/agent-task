#!/usr/bin/env bash
# Entry point for the provider-neutral issue runner (ADR 0016).
#
# The runner itself is dependency-free Node 20 under `tools/agent-task/`; this shim only
# locates it, so the command works from any directory.
#
#   scripts/agent-task doctor
#   scripts/agent-task start 186 --provider claude
#   scripts/agent-task release 186
set -euo pipefail

exec node "$(dirname "$0")/../tools/agent-task/cli.js" "$@"
